# Brand Brain Staging Environment
# Copy this file to .env.staging and fill in the values

# Database
POSTGRES_DB=brandbrain
POSTGRES_USER=brandbrain
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_32_CHARS

# AI Provider (mock | openai | anthropic)
AI_DEFAULT_PROVIDER=mock
AI_MODEL=
# Leave empty to use provider defaults:
#   openai: gpt-4o-mini
#   anthropic: claude-haiku-4-5-20251001

# API Keys (only needed if AI_DEFAULT_PROVIDER is not mock)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Public URL (used for NEXT_PUBLIC_API_BASE_URL)
PUBLIC_URL=http://your-server-ip

# Port (default 80)
PORT=80
